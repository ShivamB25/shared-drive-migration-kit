# Copy to .env and fill in values before running scripts.

# Google Cloud project that owns the service accounts.
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"

# Service account IDs will be: ${SA_PREFIX}-001, ${SA_PREFIX}-002, ...
# Keep prefix short enough that the full account ID is <= 30 chars.
SA_PREFIX="drive-migrate"
SA_COUNT="100"
SA_START_INDEX="1"

# Google shared drive ID, not the visible shared drive name.
SHARED_DRIVE_ID="0Axxxxxxxxxxxxxxxx"

# Optional: shared drive creation target for scripts/create_shared_drive.py.
SHARED_DRIVE_NAME="Shared Drive Migration Target"

# Optional: folder ID inside the shared drive. Leave blank to target drive root.
ROOT_FOLDER_ID=""

# Optional: Workspace group that will contain service-account emails.
GROUP_EMAIL="drive-migration-uploaders@your-domain.com"

# Optional: group creation settings for scripts/create_google_group.sh.
# GROUP_ORGANIZATION defaults to the domain part of GROUP_EMAIL.
GROUP_ORGANIZATION=""
GROUP_CUSTOMER=""
GROUP_DISPLAY_NAME="Drive Migration Uploaders"
GROUP_DESCRIPTION="Service account uploaders for shared drive migration."
GROUP_TYPE="discussion"
WITH_INITIAL_OWNER="with-initial-owner"

# Local source path after your source adapter has mounted/exported data locally.
SOURCE_PATH="/path/to/source-export"
DEST_PATH=""

# Optional Modal Volume source adapter.
# Use this when the source data lives in a Modal Volume and should be packaged
# inside Modal before upload to the shared drive.
SOURCE_ADAPTER="local-path"
MODAL_SOURCE_VOLUME_NAME=""
MODAL_CREDS_VOLUME_NAME="sdmig-credentials"
MODAL_STATE_VOLUME_NAME="sdmig-state"
MODAL_CACHE_VOLUME_NAME="sdmig-cache"
MODAL_MAX_CONTAINERS="10"
MODAL_WORKER_COUNT="10"
MODAL_REMOTE_GROUP_SIZE="10"
MODAL_CPU="2"
MODAL_MEMORY="4096"
MODAL_EPHEMERAL_DISK="524288"
MODAL_TIMEOUT="43200"
MODAL_PACKAGE_FORMAT="tar.zst"
MODAL_COMPRESSION_LEVEL="3"
MODAL_UPLOAD_MODE="stream"
MODAL_MAX_PACKAGE_BYTES="700GiB"
MODAL_WARN_PACKAGE_BYTES="650GiB"
MODAL_SOURCE_PREFIX=""
MODAL_UNIT_DEPTH="2"
MODAL_DEST_PREFIX=""

# Output locations.
KEY_DIR="secrets/service-accounts"
INVENTORY_FILE="generated/service_accounts.csv"
RCLONE_CONFIG_OUT="generated/rclone.conf"
RCLONE_REMOTE_PREFIX="gdrive-sa"

# Rclone large-archive upload tuning.
# These defaults are for tar.zst package uploads to Google shared drives.
RCLONE_DRIVE_CHUNK_SIZE="512M"
RCLONE_TRANSFERS="1"
RCLONE_CHECKERS="4"
RCLONE_TPSLIMIT="5"
RCLONE_TPSLIMIT_BURST="0"
RCLONE_RETRIES="3"
RCLONE_LOW_LEVEL_RETRIES="20"
RCLONE_RETRIES_SLEEP="30s"
RCLONE_CONTIMEOUT="60s"
RCLONE_TIMEOUT="5m"
RCLONE_STATS="30s"
RCLONE_STATS_FILE_NAME_LENGTH="0"
RCLONE_LOG_LEVEL="INFO"
RCLONE_DRIVE_STOP_ON_UPLOAD_LIMIT="1"
MODAL_MAX_UPLOADS_PER_REMOTE="0"

# Safety switch: scripts that change cloud state only apply when APPLY=1.
APPLY="0"
